{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "rootDir": ".",
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "tsup.config.ts", "vitest.config.ts"]
}
